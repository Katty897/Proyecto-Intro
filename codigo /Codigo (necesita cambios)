# SECCIÓN 2: LÓGICA DE COMBATE (con recursividad)
# ============================================================

def calcular_danio(atk, def_):
    """
    Daño = ATK atacante - DEF defensor.
    Mínimo siempre 1.
    """
    return max(atk - def_, 1)


def obtener_personajes_vivos(lista, index=0, resultado=None):
    """
    Recursiva: filtra personajes que NO están en KO.
    Caso base: llegó al final → retorna lista de vivos.
    Caso recursivo: agrega si vivo, avanza.
    """
    if resultado is None:
        resultado = []
    if index >= len(lista):
        return resultado
    if not lista[index]["ko"]:
        resultado.append(lista[index])
    return obtener_personajes_vivos(lista, index + 1, resultado)


def todos_ko(lista, index=0):
    """
    Recursiva: verifica si TODOS están en KO.
    Caso base: llegó al final sin encontrar vivo → True.
    Caso recursivo: si encuentra uno vivo → False.
    """
    if index >= len(lista):
        return True
    if not lista[index]["ko"]:
        return False
    return todos_ko(lista, index + 1)


def siguiente_vivo(lista, index=0):
    """
    Recursiva: retorna el primer personaje vivo.
    Caso base: llegó al final → None (no hay vivos).
    Caso recursivo: si vivo retórnalo, si no avanza.
    """
    if index >= len(lista):
        return None
    if not lista[index]["ko"]:
        return lista[index]
    return siguiente_vivo(lista, index + 1)


def obtener_seleccionados(vars_lista, personajes, index=0, resultado=None):
    """
    Recursiva: retorna personajes cuyo BooleanVar está marcado.
    Caso base: llegó al final → retorna seleccionados.
    Caso recursivo: si marcado lo agrega, avanza.
    """
    if resultado is None:
        resultado = []
    if index >= len(vars_lista):
        return resultado
    if vars_lista[index].get():
        resultado.append(personajes[index])
    return obtener_seleccionados(vars_lista, personajes, index + 1, resultado)


def restaurar_vida(p):
    """Restaura vida al máximo cuando un personaje es capturado."""
    p["vida"] = p["vida_max"]
    p["ko"]   = False
    return p


def copiar_personaje(p):
    """Crea una copia del diccionario de un personaje."""
    return {k: v for k, v in p.items()}


