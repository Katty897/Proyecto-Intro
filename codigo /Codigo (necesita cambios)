    # --------------------------------------------------------
    # SECCIÓN 4.6: LÓGICA DE TURNOS
    # --------------------------------------------------------

    def turno_jugador_ataque(self):
        """Turno del jugador: ataca, luego el Hueco responde aleatoriamente."""
        pj = self.personaje_jugador_activo
        ph = self.personaje_hueco_activo

        danio_j = calcular_danio(pj["ataque"], ph["defensa"])
        ph["vida"] -= danio_j
        log = f"⚔ {pj['nombre']} atacó a {ph['nombre']} causando {danio_j} de daño!"

        if ph["vida"] <= 0:
            ph["vida"] = 0
            ph["ko"]   = True
            log += f"\n✨ ¡{ph['nombre']} fue derrotada! La capturas."
            self.puntaje_jugador += 1
            self.equipo_jugador.append(restaurar_vida(copiar_personaje(ph)))
            if todos_ko(self.equipo_hueco):
                self.actualizar_log(log)
                self.root.after(1000, self.victoria_batalla)
                return
            self.personaje_hueco_activo = siguiente_vivo(self.equipo_hueco)
            log += f"\n🔄 La Hueca envía a {self.personaje_hueco_activo['nombre']}!"
            self.actualizar_log(log)
            self.root.after(900, self.mostrar_batalla)
            return

        log += self.turno_hueco()
        self.actualizar_log(log)
        self.root.after(700, self.mostrar_batalla)

    def turno_hueco(self):
        """
        El Hueco actúa de forma completamente aleatoria:
        70% atacar, 30% cambiar de personaje.
        """
        pj = self.personaje_jugador_activo
        ph = self.personaje_hueco_activo
        vivos = obtener_personajes_vivos(self.equipo_hueco)
        accion = random.choices(["atacar", "cambiar"], weights=[70, 30])[0]

        if accion == "cambiar" and len(vivos) > 1:
            opciones = [p for p in vivos if p["nombre"] != ph["nombre"]]
            if opciones:
                self.personaje_hueco_activo = random.choice(opciones)
                return f"\n🔄 La Hueca cambia a {self.personaje_hueco_activo['nombre']}!"

        danio_h = calcular_danio(ph["ataque"], pj["defensa"])
        pj["vida"] -= danio_h
        log = f"\n💜 {ph['nombre']} atacó a {pj['nombre']} causando {danio_h} de daño!"

        if pj["vida"] <= 0:
            pj["vida"] = 0
            pj["ko"]   = True
            log += f"\n💀 ¡{pj['nombre']} fue derrotada! La Hueca la captura."
            self.puntaje_hueco += 1
            self.equipo_hueco.append(restaurar_vida(copiar_personaje(pj)))
            if todos_ko(self.equipo_jugador):
                self.actualizar_log(log)
                self.root.after(1000, self.derrota_batalla)
                return ""
            self.personaje_jugador_activo = siguiente_vivo(self.equipo_jugador)
            log += f"\n➡  Envías a {self.personaje_jugador_activo['nombre']}!"
        return log

    def actualizar_log(self, texto):
        try:
            self.label_log.config(text=texto)
            self.label_log.update()
        except Exception:
            pass

    # --------------------------------------------------------
    # SECCIÓN 4.7: CAMBIO DE PERSONAJE
    # --------------------------------------------------------

    def mostrar_cambio_personaje(self):
        vivos = [p for p in self.equipo_jugador
                 if not p["ko"] and
                 p["nombre"] != self.personaje_jugador_activo["nombre"]]
        if not vivos:
            messagebox.showinfo("Sin opciones", "No tienes otras princesas disponibles.")
            return

        v = tk.Toplevel(self.root)
        v.title("Cambiar princesa")
        v.configure(bg=C_FONDO)
        v.geometry("340x260")
        v.resizable(False, False)

        tk.Label(v, text="Elige tu nueva princesa:",
                 font=F_GRANDE, fg=C_TEXTO, bg=C_FONDO).pack(pady=14)

        def seleccionar(p):
            self.personaje_jugador_activo = p
            v.destroy()
            self.mostrar_batalla()

        for p in vivos:
            txt = f"{p['emoji']} {p['nombre']}  ❤ {p['vida']}/{p['vida_max']}"
            tk.Button(v, text=txt, font=F_NORMAL,
                      command=lambda x=p: seleccionar(x),
                      bg=C_PANEL, fg=C_TEXTO, relief="flat",
                      padx=8, pady=7, cursor="hand2",
                      activebackground=C_ACENTO,
                      activeforeground=C_BLANCO,
                      highlightthickness=1,
                      highlightbackground=C_BORDE
                      ).pack(fill="x", padx=20, pady=4)

    # --------------------------------------------------------
    # SECCIÓN 4.8: RESULTADO DE BATALLA
    # --------------------------------------------------------

    def victoria_batalla(self):
        self.limpiar()
        cab = tk.Frame(self.contenedor, bg=C_VERDE, pady=14)
        cab.pack(fill="x")
        tk.Label(cab, text="🎉  ¡VICTORIA!",
                 font=("Georgia", 26, "bold"), fg=C_BLANCO,
                 bg=C_VERDE).pack()

        tk.Label(self.contenedor,
                 text=f"¡Derrotaste a la {self.hueco_actual['nombre']}!",
                 font=F_GRANDE, fg=C_TEXTO, bg=C_FONDO).pack(pady=14)
        tk.Label(self.contenedor,
                 text=f"Puntaje acumulado: {self.puntaje_jugador}",
                 font=("Georgia", 14), fg=C_ACENTO, bg=C_FONDO).pack()

        self.huecos_derrotados.append(self.hueco_actual)
        self.hueco_index += 1

        if self.hueco_index >= len(self.HUECOS):
            self.root.after(1200, self.fin_juego_victoria)
        else:
            self.btn(self.contenedor, "🗺  Ir al Mapa", self.mostrar_mapa, pady=20)

    def derrota_batalla(self):
        self.limpiar()
        cab = tk.Frame(self.contenedor, bg=C_ACENTO, pady=14)
        cab.pack(fill="x")
        tk.Label(cab, text="💀  DERROTA",
                 font=("Georgia", 26, "bold"), fg=C_BLANCO,
                 bg=C_ACENTO).pack()

        tk.Label(self.contenedor,
                 text=f"La {self.hueco_actual['nombre']} te venció.",
                 font=F_GRANDE, fg=C_TEXTO, bg=C_FONDO).pack(pady=14)
        tk.Label(self.contenedor,
                 text="¡Las historias están en peligro!",
                 font=F_NORMAL, fg=C_SUAVE, bg=C_FONDO).pack()
        self.btn(self.contenedor, "🔄  Volver al Inicio",
                 self.reiniciar_juego, pady=20)

    def fin_juego_victoria(self):
        self.limpiar()
        cab = tk.Frame(self.contenedor, bg=C_ACENTO, pady=18)
        cab.pack(fill="x")
        tk.Label(cab, text="👑  ¡ERES LA GUARDIANA!",
                 font=("Georgia", 22, "bold"), fg=C_BLANCO,
                 bg=C_ACENTO).pack()

        tk.Label(self.contenedor,
                 text="Derrotaste a todas las Huecas.\n¡Las historias están a salvo! ✨",
                 font=("Georgia", 14), fg=C_TEXTO,
                 bg=C_FONDO, justify="center").pack(pady=20)
        tk.Label(self.contenedor,
                 text=f"Puntaje final: {self.puntaje_jugador}",
                 font=("Georgia", 20, "bold"), fg=C_VERDE,
                 bg=C_FONDO).pack()
        self.btn(self.contenedor, "🔄  Jugar de Nuevo",
                 self.reiniciar_juego, pady=24)

    def reiniciar_juego(self):
        self.todos_personajes = cargar_personajes()
        self.mostrar_pantalla_inicio()


