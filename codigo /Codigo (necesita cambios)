        if not nombre:
            messagebox.showerror("¡Espera!", "Ingresa tu nombre para continuar.")
            return
        seleccionados = obtener_seleccionados(self.vars_personajes, self.todos_personajes)
        if len(seleccionados) != 3:
            messagebox.showerror("¡Espera!",
                                 f"Debes elegir exactamente 3 princesas.\n"
                                 f"(Seleccionadas: {len(seleccionados)})")
            return
        self.nombre_jugador    = nombre
        self.avatar_jugador    = self.avatar_var.get()
        self.equipo_jugador    = [copiar_personaje(p) for p in seleccionados]
        self.puntaje_jugador   = 0
        self.hueco_index       = 0
        self.huecos_derrotados = []
        self.mostrar_mapa()

