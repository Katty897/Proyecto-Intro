    def titulo(self, parent, texto, color=None, fuente=None, pady=4):
        tk.Label(parent, text=texto,
                 font=fuente or F_TITULO,
                 fg=color or C_ACENTO,
                 bg=parent.cget("bg")).pack(pady=pady)

    def label(self, parent, texto, color=None, fuente=None, bg=None, anchor="center", pady=2):
        tk.Label(parent, text=texto,
                 font=fuente or F_NORMAL,
                 fg=color or C_TEXTO,
                 bg=bg or parent.cget("bg"),
                 anchor=anchor).pack(pady=pady, anchor=anchor if anchor != "center" else None)

    def btn(self, parent, texto, cmd, bg=None, fg="white", width=22, pady=5, side=None):
        b = tk.Button(parent, text=texto, command=cmd,
                      font=F_NORMAL, bg=bg or C_ACENTO, fg=fg,
                      activebackground=C_VERDE, activeforeground="white",
                      relief="flat", bd=0, padx=12, pady=7,
                      width=width, cursor="hand2",
                      highlightthickness=0)
        if side:
            b.pack(side=side, padx=6, pady=pady)
        else:
            b.pack(pady=pady)
        return b

    def barra_vida(self, parent, hp, hp_max, ancho=220):
        """Dibuja una barra de vida coloreada según el porcentaje restante."""
        c = tk.Canvas(parent, width=ancho, height=18,
                      bg=C_PANEL, highlightthickness=1,
                      highlightbackground=C_BORDE)
        c.pack(pady=3)
        pct = max(hp, 0) / hp_max
        color = (C_VERDE if pct > 0.5 else C_AMARILLO if pct > 0.25 else C_ACENTO)
        c.create_rectangle(2, 2, ancho - 2, 16, fill="#F5D0DA", outline="")
        c.create_rectangle(2, 2, int((ancho - 2) * pct), 16, fill=color, outline="")
        c.create_text(ancho // 2, 9,
                      text=f"{max(hp,0)}/{hp_max}",
                      fill=C_TEXTO, font=("Helvetica", 8, "bold"))
        return c

