# SECCIÓN 1: CARGA DE PERSONAJES DESDE ARCHIVO
# ============================================================
def cargar_personajes(ruta="personajes.txt"):
    """
    Carga los personajes desde el archivo de texto.
    Usa recursividad para procesar cada línea.
    """
    try:
        with open(ruta, "r", encoding="utf-8") as f:
            lineas = [l.strip() for l in f.readlines()
                      if l.strip() and not l.startswith("#")]
    except FileNotFoundError:
        lineas = [
            "MULAN,Mulan,Ataque,55,28,8,\U0001f338",
            "MOANA,Moana,Balanceado,60,22,12,\U0001f30a",
            "ELSA,Frozen,Ataque,50,32,7,\u2744\ufe0f",
            "RAPUNZEL,Enredados,Balanceado,62,20,13,\U0001f451",
            "MERIDA,Valiente,Ataque,52,30,9,\U0001f3f9",
            "POCAHONTAS,Pocahontas,Balanceado,60,20,14,\U0001f343",
            "CENICIENTA,La Cenicienta,Defensa,75,14,18,\U0001f460",
            "BELLA,La Bella y la Bestia,Balanceado,58,22,10,\U0001f339",
            "ARIEL,La Sirenita,Ataque,50,31,6,\U0001f420",
            "TIANA,Princesa y el Sapo,Balanceado,62,21,12,\U0001f438",
            "AURORA,La Bella Durmiente,Defensa,70,15,17,\U0001f337",
            "JASMINE,Aladdin,Ataque,53,29,8,\u2728",
            "MIRABEL,Encanto,Balanceado,60,20,15,\U0001f98b",
            "RAYA,Raya y el Ultimo Dragon,Ataque,55,33,6,\U0001f409",
            "VAIANA,Vaiana,Balanceado,58,21,11,\U0001f41a",
        ]

    def leer_lineas(lista, index=0, resultado=None):
        """
        Recursiva: procesa cada línea del archivo.
        Caso base: índice al final → retorna resultado.
        Caso recursivo: parsea línea actual y avanza.
        """
        if resultado is None:
            resultado = []
        # Caso base
        if index >= len(lista):
            return resultado
        partes = lista[index].split(",")
        if len(partes) >= 7:
            p = {
                "nombre":   partes[0],
                "pelicula": partes[1],
                "rol":      partes[2],
                "vida_max": int(partes[3]),
                "vida":     int(partes[3]),
                "ataque":   int(partes[4]),
                "defensa":  int(partes[5]),
                "emoji":    partes[6],
                "ko":       False,
            }
            resultado.append(p)
        # Caso recursivo
        return leer_lineas(lista, index + 1, resultado)

    return leer_lineas(lineas)


